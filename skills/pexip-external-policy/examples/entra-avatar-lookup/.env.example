# --- Pexip policy HTTP Basic Auth ---
# Must match the credentials configured on the Pexip Policy Profile.
POLICY_USER=pexip
POLICY_PASS=change-me

# --- Microsoft Entra (Azure AD) app registration ---
# Required Microsoft Graph application permission: User.Read.All
# (admin-granted; needed to read /users/{upn}/photo/$value).
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- Photo cache ---
# How long (in seconds) a fetched photo (or "no photo" result) is cached
# in memory before Graph is queried again. 3600 = 1 hour.
PHOTO_CACHE_TTL=3600

# --- Logging ---
LOG_LEVEL=INFO
